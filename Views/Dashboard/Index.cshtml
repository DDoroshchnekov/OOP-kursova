@model List<TimeTrackerWeb.Domain.TimeEntry>

@{
    ViewData["Title"] = "Dashboard";

    string FormatSeconds(int seconds)
    {
        var ts = TimeSpan.FromSeconds(seconds);
        return $"{(int)ts.TotalHours:D2}:{ts.Minutes:D2}:{ts.Seconds:D2}";
    }
}

<div class="container mt-4">
    <h2 class="mb-4">Dashboard</h2>

    <div class="mb-4">
        <a asp-controller="Projects" asp-action="Index" class="btn btn-primary me-2">Перейти до проєктів</a>
    </div>

    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card p-3">
                <h5>Проєкти</h5>
                <p class="mb-0">@ViewBag.ProjectsCount</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card p-3">
                <h5>Задачі</h5>
                <p class="mb-0">@ViewBag.TasksCount</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card p-3">
                <h5>Активні задачі</h5>
                <p class="mb-0">@ViewBag.ActiveTasksCount</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card p-3">
                <h5>Загальний час</h5>
                <p class="mb-0">@FormatSeconds((int)ViewBag.TotalSeconds)</p>
            </div>
        </div>
    </div>

    <div class="card p-3">
        <h4 class="mb-3">Останні записи часу</h4>

        @if (Model != null && Model.Any())
        {
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Проєкт</th>
                        <th>Задача</th>
                        <th>Початок</th>
                        <th>Кінець</th>
                        <th>Тривалість</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var entry in Model)
                    {
                        <tr>
                            <td>@entry.TaskItem?.Project?.Name</td>
                            <td>@entry.TaskItem?.Title</td>
                            <td>@entry.StartTimeUtc.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                            <td>@(entry.EndTimeUtc.HasValue ? entry.EndTimeUtc.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm") : "-")</td>
                            <td>@FormatSeconds(entry.DurationSeconds)</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="mb-0">Записів поки немає.</p>
        }
    </div>
</div>